# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (local Docker PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sport_predictor?schema=public"

# Auth.js / NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- OAuth Providers (configure at least one) ---

# Google (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Microsoft Entra ID (https://portal.azure.com → App registrations)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Optional: restrict to a single tenant (default: "common" = any Microsoft account)
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# API-Football v3 (https://www.api-football.com/)
FOOTBALL_API_KEY=
